# ─────────────────────────────────────────────────────────────
# SamarthX — Environment Variables
# Copy to `.env` and fill in real values before deploying.
# ─────────────────────────────────────────────────────────────

# ── Database (REQUIRED) ──
# Postgres connection string used by Payload CMS AND the raw applicant auth pool.
# Note: the variable name is CMS_DATABASE_URL (not DATABASE_URL).
CMS_DATABASE_URL=postgres://user:password@host:5432/samarthx

# ── Payload (REQUIRED) ──
# Secret used by Payload to sign/encrypt its own tokens. Use a long random string.
PAYLOAD_SECRET=change-me-to-a-long-random-string

# ── Applicant Auth (REQUIRED in production) ──
# Signs applicant JWT cookies. If unset, the code falls back to an INSECURE default.
JWT_SECRET=change-me-to-a-long-random-string

# Public base URL of the site. Used to build password-reset links in emails.
# MUST be set in production, otherwise reset links point to http://localhost:3888.
NEXT_PUBLIC_APP_URL=https://your-domain.gov.in

# ── Server Actions stability (RECOMMENDED for production) ──
# Pins the Next.js Server Action encryption key so admin panel actions stay valid
# across redeploys and multiple instances. Prevents the
# "Failed to find Server Action" error after a deploy.
# Generate with: openssl rand -base64 32
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=change-me-32-byte-base64-key

# ── Email / SMTP (required for OTP + password-reset emails) ──
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_SENDER_EMAIL=no-reply@your-domain.gov.in

# ── Uploads (optional) ──
# Directory where applicant resumes are stored. Defaults to "resumes".
CMS_RESUMES_UPLOAD_DIR=resumes

# ── Runtime ──
NODE_ENV=production
